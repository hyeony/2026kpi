{
  "name": "test2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "build:core": "turbo run build --filter=@test2/core",
    "build:theme": "turbo run build --filter=@test2/theme",
    "dev": "turbo run build --filter=@test2/core --filter=@test2/theme && turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "turbo": "^2.3.0"
  }
}
