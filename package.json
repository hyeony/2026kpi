{
  "name": "test2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm run build:core && pnpm run build:theme && pnpm --filter playground build",
    "build:core": "pnpm --filter @test2/core build",
    "build:theme": "pnpm --filter @test2/theme build",
    "dev": "pnpm run build:core && pnpm run build:theme && pnpm run dev:all",
    "dev:all": "concurrently \"pnpm --filter @test2/core dev\" \"pnpm --filter @test2/theme dev\" \"pnpm --filter playground dev\"",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r run lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
